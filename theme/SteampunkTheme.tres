[gd_resource type="Theme" format=3 uid="uid://aurora_theme"]

; ──────────────────────────────────────────────
;  Aurora Dusk: Steam Age — Steampunk UI Theme
;  Godot 4.x Theme Resource (.tres)
;
;  Color palette reference:
;    Copper/Amber  #B8841F  → Color(0.72, 0.52, 0.12)
;    Dark Iron     #1E1712  → Color(0.12, 0.09, 0.07)
;    Rust Highlight #C8570A → Color(0.78, 0.34, 0.04)
;    Parchment     #E8D9B0  → Color(0.91, 0.85, 0.69)
;    Steam White   #D8CFC0  → Color(0.85, 0.81, 0.75)
; ──────────────────────────────────────────────

[resource]
; ── Button — Normal State ────────────────────
Button/colors/font_color              = Color(0.91, 0.85, 0.69, 1.0)
Button/colors/font_hover_color        = Color(0.98, 0.92, 0.72, 1.0)
Button/colors/font_pressed_color      = Color(1.0,  0.78, 0.30, 1.0)
Button/colors/font_focus_color        = Color(0.98, 0.92, 0.72, 1.0)
Button/colors/font_disabled_color     = Color(0.55, 0.50, 0.40, 0.55)
Button/colors/icon_normal_color       = Color(1.0, 1.0, 1.0, 1.0)
Button/constants/h_separation         = 12

; ── Label ───────────────────────────────────
Label/colors/font_color               = Color(0.91, 0.85, 0.69, 1.0)
Label/colors/font_shadow_color        = Color(0.0,  0.0,  0.0,  0.7)
Label/constants/shadow_offset_x       = 2
Label/constants/shadow_offset_y       = 2

; ── HSeparator ──────────────────────────────
HSeparator/colors/separator_color     = Color(0.72, 0.52, 0.18, 0.5)
HSeparator/constants/separation       = 8

; ── ItemList ────────────────────────────────
ItemList/colors/font_color            = Color(0.91, 0.85, 0.69, 1.0)
ItemList/colors/font_selected_color   = Color(1.0,  0.85, 0.40, 1.0)
ItemList/colors/guide_color           = Color(0.72, 0.52, 0.18, 0.3)
ItemList/colors/font_hovered_color    = Color(0.98, 0.92, 0.72, 1.0)

; ── HSlider ─────────────────────────────────
HSlider/colors/tick_color             = Color(0.72, 0.52, 0.18, 0.8)

; ── CheckBox ────────────────────────────────
CheckBox/colors/font_color            = Color(0.91, 0.85, 0.69, 1.0)
CheckBox/colors/font_hover_color      = Color(0.98, 0.92, 0.72, 1.0)

; ── OptionButton ────────────────────────────
OptionButton/colors/font_color        = Color(0.91, 0.85, 0.69, 1.0)
OptionButton/colors/font_hover_color  = Color(0.98, 0.92, 0.72, 1.0)
