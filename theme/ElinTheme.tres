; ════════════════════════════════════════════════════════════
;  RESOURCE — bind everything to widget types
; ════════════════════════════════════════════════════════════

[resource]

; ── Button ───────────────────────────────────────────────────
Button/styles/normal   = SubResource("btn_normal")
Button/styles/hover    = SubResource("btn_hover")
Button/styles/pressed  = SubResource("btn_pressed")
Button/styles/focus    = SubResource("btn_focus")
Button/styles/disabled = SubResource("btn_disabled")
Button/colors/font_color          = Color(0.228, 0.145, 0.063, 1)
Button/colors/font_hover_color    = Color(0.160, 0.090, 0.025, 1)
Button/colors/font_pressed_color  = Color(0.140, 0.080, 0.020, 1)
Button/colors/font_focus_color    = Color(0.228, 0.145, 0.063, 1)
Button/colors/font_disabled_color = Color(0.520, 0.460, 0.350, 0.65)
Button/constants/h_separation = 10
Button/font_sizes/font_size = 20

; ── Panel / PanelContainer ────────────────────────────────────
Panel/styles/panel          = SubResource("panel_main")
PanelContainer/styles/panel = SubResource("panel_main")

; ── Label ─────────────────────────────────────────────────────
Label/colors/font_color        = Color(0.228, 0.145, 0.063, 1)
Label/colors/font_shadow_color = Color(0, 0, 0, 0)
Label/font_sizes/font_size     = 20

; ── TabContainer ──────────────────────────────────────────────
TabContainer/styles/tab_selected   = SubResource("tab_selected")
TabContainer/styles/tab_unselected = SubResource("tab_unselected")
TabContainer/styles/tab_hovered    = SubResource("tab_hover")
TabContainer/styles/panel          = SubResource("tab_panel")
TabContainer/colors/font_selected_color   = Color(0.228, 0.145, 0.063, 1)
TabContainer/colors/font_unselected_color = Color(0.490, 0.400, 0.245, 1)
TabContainer/colors/font_hovered_color    = Color(0.200, 0.130, 0.055, 1)
TabContainer/font_sizes/font_size         = 20
TabContainer/constants/side_margin        = 8

; ── ScrollContainer ───────────────────────────────────────────
ScrollContainer/styles/panel = SubResource("scroll_empty")

; ── HSlider ───────────────────────────────────────────────────
HSlider/styles/slider            = SubResource("slider_track")
HSlider/styles/grabber_area      = SubResource("slider_fill")
HSlider/styles/grabber_area_highlight = SubResource("slider_fill")
HSlider/constants/grabber_offset = 0

; ── CheckBox ──────────────────────────────────────────────────
; font_hover_color        : slightly lighter/muted for unchecked hover (the "good" lightening effect)
; font_hover_pressed_color: identical to normal so CHECKED + hover text never turns white
CheckBox/colors/font_color               = Color(0.228, 0.145, 0.063, 1)
CheckBox/colors/font_hover_color         = Color(0.490, 0.390, 0.240, 1)
CheckBox/colors/font_pressed_color       = Color(0.228, 0.145, 0.063, 1)
CheckBox/colors/font_hover_pressed_color = Color(0.228, 0.145, 0.063, 1)
CheckBox/colors/font_focus_color         = Color(0.228, 0.145, 0.063, 1)
CheckBox/colors/font_disabled_color      = Color(0.520, 0.460, 0.350, 0.65)
CheckBox/styles/normal        = SubResource("btn_normal")
CheckBox/styles/hover         = SubResource("btn_hover")
CheckBox/styles/pressed       = SubResource("btn_pressed")
CheckBox/styles/hover_pressed = SubResource("btn_hover")
CheckBox/styles/focus         = SubResource("btn_focus")
CheckBox/styles/disabled      = SubResource("btn_disabled")
CheckBox/font_sizes/font_size = 20

; ── OptionButton ──────────────────────────────────────────────
OptionButton/colors/font_color       = Color(0.228, 0.145, 0.063, 1)
OptionButton/colors/font_hover_color = Color(0.140, 0.080, 0.020, 1)
OptionButton/styles/normal   = SubResource("btn_normal")
OptionButton/styles/hover    = SubResource("btn_hover")
OptionButton/styles/pressed  = SubResource("btn_pressed")
OptionButton/styles/focus    = SubResource("btn_focus")
OptionButton/font_sizes/font_size = 20

; ── PopupMenu ─────────────────────────────────────────────────
PopupMenu/styles/panel          = SubResource("popup_panel")
PopupMenu/styles/hover          = SubResource("popup_item_hover")
PopupMenu/colors/font_color     = Color(0.228, 0.145, 0.063, 1)
PopupMenu/colors/font_hover_color = Color(0.140, 0.080, 0.020, 1)
PopupMenu/font_sizes/font_size  = 20

; ── LineEdit ──────────────────────────────────────────────────
LineEdit/styles/normal = SubResource("lineedit_normal")
LineEdit/styles/focus  = SubResource("lineedit_focus")
LineEdit/colors/font_color             = Color(0.228, 0.145, 0.063, 1)
LineEdit/colors/font_placeholder_color = Color(0.228, 0.145, 0.063, 0.45)
LineEdit/colors/cursor_color           = Color(0.380, 0.259, 0.125, 1)
LineEdit/colors/selection_color        = Color(0.770, 0.690, 0.510, 0.8)
LineEdit/font_sizes/font_size          = 20

; ── ItemList ──────────────────────────────────────────────────
ItemList/styles/panel    = SubResource("itemlist_bg")
ItemList/styles/selected = SubResource("itemlist_selected")
ItemList/styles/selected_focus = SubResource("itemlist_selected")
ItemList/colors/font_color          = Color(0.228, 0.145, 0.063, 1)
ItemList/colors/font_selected_color = Color(0.140, 0.080, 0.020, 1)
ItemList/colors/guide_color         = Color(0.380, 0.259, 0.125, 0.25)
ItemList/font_sizes/font_size       = 20

; ── HSeparator ────────────────────────────────────────────────
HSeparator/colors/separator_color = Color(0.380, 0.259, 0.125, 0.40)
HSeparator/constants/separation   = 8
