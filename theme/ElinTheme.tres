[gd_resource type="Theme" format=3 uid="uid://elin_theme"]

; ──────────────────────────────────────────────────────────────
;  Aurora Dusk: Steam Age — Elin-Inspired Parchment UI Theme
;  Godot 4.x  |  .tres resource
;
;  Palette:
;    Parchment Light  #EEE2C4  Color(0.933, 0.886, 0.769)
;    Parchment Mid    #E7D9B8  Color(0.906, 0.851, 0.722)
;    Parchment Shadow #DDD0A8  Color(0.867, 0.816, 0.659)
;    Parchment Dark   #D0C090  Color(0.816, 0.753, 0.565)
;    Ink Brown        #3A2510  Color(0.228, 0.145, 0.063)
;    Header Brown     #6B3E12  Color(0.420, 0.243, 0.071)
;    Border Brown     #614220  Color(0.380, 0.259, 0.125)
;    Tab Inactive     #C5B88A  Color(0.773, 0.722, 0.541)
;    Rust Accent      #8B3A12  Color(0.545, 0.228, 0.071)
; ──────────────────────────────────────────────────────────────

; ── Button ───────────────────────────────────────────────────

[sub_resource type="StyleBoxFlat" id="btn_normal"]
bg_color = Color(0.867, 0.816, 0.659, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.380, 0.259, 0.125, 0.85)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4
content_margin_left = 14
content_margin_top = 8
content_margin_right = 14
content_margin_bottom = 8
shadow_color = Color(0, 0, 0, 0.18)
shadow_size = 3
shadow_offset = Vector2(1, 2)

[sub_resource type="StyleBoxFlat" id="btn_hover"]
bg_color = Color(0.906, 0.851, 0.722, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.420, 0.290, 0.130, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4
content_margin_left = 14
content_margin_top = 8
content_margin_right = 14
content_margin_bottom = 8
shadow_color = Color(0, 0, 0, 0.22)
shadow_size = 4
shadow_offset = Vector2(1, 2)

[sub_resource type="StyleBoxFlat" id="btn_pressed"]
bg_color = Color(0.770, 0.718, 0.575, 1)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.300, 0.200, 0.090, 1.0)
corner_radius_top_left = 4
corner_radius_top_right = 4
corner_radius_bottom_right = 4
corner_radius_bottom_left = 4
content_margin_left = 14
content_margin_top = 8
content_margin_right = 14
content_margin_bottom = 8

[sub_resource type="StyleBoxFlat" id="btn_focus"]
bg_color = Color(0, 0, 0, 0)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.545, 0.380, 0.140, 1.0)
