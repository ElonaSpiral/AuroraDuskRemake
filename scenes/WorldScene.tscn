[gd_scene load_steps=6 format=3 uid="uid://aurora_world"]

[ext_resource type="Script" path="res://scripts/WorldScene.gd"      id="1_script"]
[ext_resource type="Script" path="res://scripts/WorldRenderer.gd"   id="2_renderer"]
[ext_resource type="Script" path="res://scripts/MinimapDrawer.gd"   id="3_minimap"]
[ext_resource type="Theme"  path="res://theme/ElinTheme.tres"       id="4_theme"]
[ext_resource type="Script" path="res://scripts/RTSController.gd"   id="5_rts"]

; ──────────────────────────────────────────────────────────────
;  WorldScene — Phase 2 game world with RTS controls
;
;  Node2D  (WorldScene)
;  ├── WorldCamera  (Camera2D)
;  ├── WorldRenderer  (Node2D — terrain drawn via _draw())
;  ├── UnitsLayer   (Node2D — parent for all RTSUnit nodes)
;  ├── RTSController (Node2D — input + selection + orders)
;  └── HUDLayer  (CanvasLayer, layer=10)
;      └── HUD  (Control, full-viewport)
;          ├── TopBar        (mode / map / char)
;          ├── Minimap       (top-right)
;          ├── BottomBar     (terrain / coords / selection)
;          ├── BtnBack       (bottom-left)
;          └── BtnGrid       (bottom-right)
; ──────────────────────────────────────────────────────────────

[node name="WorldScene" type="Node2D"]
script = ExtResource("1_script")

; ── Camera ────────────────────────────────────────────────────
[node name="WorldCamera" type="Camera2D" parent="."]
zoom          = Vector2(1.5, 1.5)
position_smoothing_enabled = true
position_smoothing_speed   = 8.0

; ── Terrain renderer ──────────────────────────────────────────
[node name="WorldRenderer" type="Node2D" parent="."]
script = ExtResource("2_renderer")

; ── Units layer — holds all RTSUnit Node2D children ───────────
[node name="UnitsLayer" type="Node2D" parent="."]
z_index = 2

; ── RTS Controller — selection box + input handling ──────────
[node name="RTSController" type="Node2D" parent="."]
script  = ExtResource("5_rts")
z_index = 3

; ── HUD overlay ───────────────────────────────────────────────
[node name="HUDLayer" type="CanvasLayer" parent="."]
layer = 10

[node name="HUD" type="Control" parent="HUDLayer"]
layout_mode    = 3
anchors_preset = 15
anchor_right   = 1.0
anchor_bottom  = 1.0
theme          = ExtResource("4_theme")
mouse_filter   = 2

; ── Top bar ───────────────────────────────────────────────────
[node name="TopBar" type="PanelContainer" parent="HUDLayer/HUD"]
layout_mode   = 1
anchor_left   = 0.0
anchor_top    = 0.0
anchor_right  = 0.76
anchor_bottom = 0.0
offset_top    = 8.0
offset_left   = 8.0
offset_right  = -8.0
offset_bottom = 56.0

[node name="TopMargin" type="MarginContainer" parent="HUDLayer/HUD/TopBar"]
layout_mode = 2
theme_override_constants/margin_left   = 12
theme_override_constants/margin_top    = 4
theme_override_constants/margin_right  = 12
theme_override_constants/margin_bottom = 4

[node name="TopHBox" type="HBoxContainer" parent="HUDLayer/HUD/TopBar/TopMargin"]
layout_mode                         = 2
theme_override_constants/separation = 16

[node name="LblMode" type="Label" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2
text        = "Mode"
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.420, 0.243, 0.071, 1.0)

[node name="TopSep1" type="VSeparator" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2

[node name="LblMapLabel" type="Label" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2
text        = "Map:"
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.380, 0.259, 0.125, 1.0)

[node name="MapPicker" type="OptionButton" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode         = 2
custom_minimum_size = Vector2(180, 0)
theme_override_font_sizes/font_size = 17

[node name="LblMap" type="Label" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2
text        = ""
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.228, 0.145, 0.063, 1.0)
visible     = false

[node name="TopSep2" type="VSeparator" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2

[node name="LblChar" type="Label" parent="HUDLayer/HUD/TopBar/TopMargin/TopHBox"]
layout_mode = 2
text        = "No character"
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.490, 0.390, 0.240, 1.0)

; ── Minimap ───────────────────────────────────────────────────
[node name="Minimap" type="Control" parent="HUDLayer/HUD"]
layout_mode         = 1
anchor_left         = 1.0
anchor_top          = 0.0
anchor_right        = 1.0
anchor_bottom       = 0.0
offset_left         = -180.0
offset_top          = 8.0
offset_right        = -8.0
offset_bottom       = 180.0
script              = ExtResource("3_minimap")

; ── Bottom bar — terrain / coords / selection count ───────────
[node name="BottomBar" type="PanelContainer" parent="HUDLayer/HUD"]
layout_mode   = 1
anchor_left   = 0.0
anchor_top    = 1.0
anchor_right  = 0.76
anchor_bottom = 1.0
offset_left   = 8.0
offset_top    = -52.0
offset_right  = -8.0
offset_bottom = -8.0

[node name="BottomMargin" type="MarginContainer" parent="HUDLayer/HUD/BottomBar"]
layout_mode = 2
theme_override_constants/margin_left   = 12
theme_override_constants/margin_top    = 4
theme_override_constants/margin_right  = 12
theme_override_constants/margin_bottom = 4

[node name="BottomHBox" type="HBoxContainer" parent="HUDLayer/HUD/BottomBar/BottomMargin"]
layout_mode                         = 2
theme_override_constants/separation = 16

[node name="LblTerrain" type="Label" parent="HUDLayer/HUD/BottomBar/BottomMargin/BottomHBox"]
layout_mode           = 2
size_flags_horizontal = 3
text                  = ""
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.228, 0.145, 0.063, 1.0)

[node name="LblSelection" type="Label" parent="HUDLayer/HUD/BottomBar/BottomMargin/BottomHBox"]
layout_mode         = 2
custom_minimum_size = Vector2(120, 0)
text                = ""
horizontal_alignment = 1
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.20, 0.55, 1.00, 0.90)

[node name="LblCoords" type="Label" parent="HUDLayer/HUD/BottomBar/BottomMargin/BottomHBox"]
layout_mode         = 2
custom_minimum_size = Vector2(80, 0)
text                = ""
horizontal_alignment = 2
theme_override_font_sizes/font_size = 17
theme_override_colors/font_color    = Color(0.490, 0.390, 0.240, 0.85)

; ── Back ─────────────────────────────────────────────────────
[node name="BtnBack" type="Button" parent="HUDLayer/HUD"]
layout_mode         = 1
anchor_left         = 0.0
anchor_top          = 1.0
anchor_right        = 0.0
anchor_bottom       = 1.0
offset_left         = 8.0
offset_top          = -52.0
offset_right        = 160.0
offset_bottom       = -8.0
text                = "◀  BACK"
theme_override_font_sizes/font_size = 18

; ── Grid toggle ───────────────────────────────────────────────
[node name="BtnGrid" type="Button" parent="HUDLayer/HUD"]
layout_mode         = 1
anchor_left         = 1.0
anchor_top          = 1.0
anchor_right        = 1.0
anchor_bottom       = 1.0
offset_left         = -160.0
offset_top          = -52.0
offset_right        = -8.0
offset_bottom       = -8.0
text                = "Grid: OFF"
theme_override_font_sizes/font_size = 18
