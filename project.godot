; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Aurora Dusk: Steam Age"
config/description="A collaborative sandbox RPG/Strategy game - Godot 4 Recreation"
run/main_scene="res://scenes/LoadingScene.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
boot_splash/bg_color=Color(0.075, 0.055, 0.04, 1)
boot_splash/show_image=false
config/icon="res://icon.svg"

[autoload]

SettingsManager="*res://scripts/SettingsManager.gd"
UIEffects="*res://scripts/UIEffects.gd"
CharacterManager="*res://scripts/CharacterManager.gd"
FPSOverlay="*res://scripts/FPSOverlay.gd"
GroundsManager="*res://scripts/GroundsManager.gd"
MapManager="*res://scripts/MapManager.gd"
GameState="*res://scripts/GameState.gd"
ImageLayerManager="*res://scripts/ImageLayerManager.gd"
AgesManager="*res://scripts/AgesManager.gd"
EntityDataManager="*res://scripts/EntityDataManager.gd"
FactionsManager="*res://scripts/FactionsManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

textures/canvas_textures/default_texture_filter=0
